{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "TikTool",
  "colors": {
    "primary": "#22c55e",
    "light": "#4ade80",
    "dark": "#16a34a"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart",
              "authentication"
            ]
          },
          {
            "group": "WebSocket API",
            "pages": [
              "websocket/connection",
              "websocket/events",
              "websocket/close-codes"
            ]
          },
          {
            "group": "REST API",
            "pages": [
              "rest-api/overview",
              "rest-api/sign-url",
              "rest-api/check-alive",
              "rest-api/room-info",
              "rest-api/room-video",
              "rest-api/room-id",
              "rest-api/room-cover",
              "rest-api/fetch",
              "rest-api/rankings",
              "rest-api/bulk-live-check",
              "rest-api/resolve-user-ids",
              "rest-api/ws-credentials",
              "rest-api/sign-websocket",
              "rest-api/hashtag-list",
              "rest-api/gift-info",
              "rest-api/rate-limits",
              "rest-api/jwt"
            ]
          },
          {
            "group": "Live Captions",
            "pages": [
              "captions/overview",
              "captions/websocket",
              "captions/sdk"
            ]
          },
          {
            "group": "SDKs",
            "pages": [
              "sdks/nodejs",
              "sdks/python"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/unreal-engine"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "reference/rate-limits",
              "reference/error-codes"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://tik.tools",
          "icon": "globe"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/tiktool",
          "icon": "github"
        },
        {
          "anchor": "Discord",
          "href": "https://discord.gg/tiktool",
          "icon": "discord"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "https://tik.tools/help"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://tik.tools/dashboard"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/tiktool",
      "discord": "https://discord.gg/tiktool",
      "x": "https://x.com/AnyStreamIO"
    }
  }
}
